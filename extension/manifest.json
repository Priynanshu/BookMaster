{
  "manifest_version": 3,
  "name": "BookMaster — Save to Library",
  "version": "1.0.0",
  "description": "Save any webpage to your BookMaster library",

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications"
  ],

  "host_permissions": [
    "https://bookmaster-b6pk.onrender.com/*",
    "http://localhost:3000/*"
  ],

  "externally_connectable": {
    "matches": [
      "https://book-master-ruddy.vercel.app/*",
      "http://localhost:5173/*"
    ]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  }
}