{
  "manifest_version": 3,
  "name": "BookMaster — Save to Library",
  "version": "1.0.0",
  "description": "Save any webpage to your BookMaster library with one click",

  "permissions": [
    "activeTab",
    "storage",
    "cookies"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "https://your-backend-url.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}